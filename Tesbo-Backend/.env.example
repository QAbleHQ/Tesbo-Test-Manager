PORT=7000
# Use either JDBC URL (jdbc:postgresql://...) or URI form (postgresql://...).
# For managed DBs, credentials can be embedded in DATABASE_URL, in which case DATABASE_USER/PASSWORD are optional.
DATABASE_URL=jdbc:postgresql://localhost:5432/bettercases
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=noreply@example.com
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
SESSION_DAYS=30
# Jira OAuth 2.0 (3LO) — register an OAuth app at https://developer.atlassian.com/console/myapps/
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:3000/jira/callback
FRONTEND_URL=http://localhost:3000

# Tesbo artifact storage: "local" (default) or "spaces"
TESBO_ARTIFACT_STORAGE_PROVIDER=local
# DigitalOcean Spaces (required when provider=spaces)
TESBO_SPACES_ENDPOINT=
TESBO_SPACES_REGION=us-east-1
TESBO_SPACES_BUCKET=
TESBO_SPACES_ACCESS_KEY=
TESBO_SPACES_SECRET_KEY=
# Signed URL expiry for private Spaces object access
TESBO_SIGNED_URL_TTL_SECONDS=600

