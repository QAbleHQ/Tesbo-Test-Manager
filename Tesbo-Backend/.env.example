PORT=7000
# Use a PostgreSQL role that exists on your server (e.g. your OS username if using Homebrew Postgres)
DATABASE_URL=jdbc:postgresql://localhost:5432/bettercases
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=noreply@example.com
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
SESSION_DAYS=30
# Jira OAuth 2.0 (3LO) — register an OAuth app at https://developer.atlassian.com/console/myapps/
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:3000/jira/callback
FRONTEND_URL=http://localhost:3000

# Tesbo artifact storage: "local" (default) or "spaces"
TESBO_ARTIFACT_STORAGE_PROVIDER=local
# DigitalOcean Spaces (required when provider=spaces)
TESBO_SPACES_ENDPOINT=
TESBO_SPACES_REGION=us-east-1
TESBO_SPACES_BUCKET=
TESBO_SPACES_ACCESS_KEY=
TESBO_SPACES_SECRET_KEY=
# Signed URL expiry for private Spaces object access
TESBO_SIGNED_URL_TTL_SECONDS=600

# Automation execution mode: "queue" runs in separate worker process and supports parallel runs.
AUTOMATION_EXECUTION_MODE=queue
AUTOMATION_AGENT_BASE_URL=http://localhost:7400
# Test-Runner-Agents queue API (enqueue/cancel/stats); default when split from automation-agent
AUTOMATION_QUEUE_API_BASE_URL=http://localhost:7410
AUTOMATION_AGENT_SHARED_TOKEN=change-me
AUTOMATION_QUEUE_MAX_RETRIES=2
AUTOMATION_QUEUE_STALE_MINUTES=5
AUTOMATION_QUEUE_SHARED_TOKEN=change-me
AUTOMATION_QUEUE_MAX_ACTIVE_RUNS_PER_PROJECT=10
AUTOMATION_QUEUE_MAX_QUEUED_JOBS_PER_PROJECT=5000
# Per-project concurrent jobs default (overridable in project settings as automation.maxConcurrentJobs)
AUTOMATION_QUEUE_DEFAULT_CONCURRENT_JOBS_PER_PROJECT=50
# Hard cap on automation.maxConcurrentJobs from project settings
AUTOMATION_QUEUE_MAX_CONCURRENT_JOBS_CEILING=200
# Jobs per HTTP batch when pushing to Redis
AUTOMATION_QUEUE_DISPATCH_BATCH_SIZE=50
AUTOMATION_QUEUE_AUTOSCALE_MIN_WORKERS=0
AUTOMATION_QUEUE_AUTOSCALE_MAX_WORKERS=50
AUTOMATION_QUEUE_AUTOSCALE_TARGET_JOBS_PER_WORKER=2
AUTOMATION_QUEUE_AUTOSCALE_WARM_WORKERS=0

# --- External Execution Service (decoupled mode) ---
# Set to "external" to delegate execution to the standalone Tesbo Execution Service.
# Set to "legacy" (default) to use embedded orchestration.
EXECUTION_SERVICE_MODE=legacy
EXECUTION_SERVICE_BASE_URL=http://localhost:7420
EXECUTION_SERVICE_API_KEY=
# Webhook URL that the Execution Service will POST state changes to (should point to this backend)
EXECUTION_SERVICE_WEBHOOK_URL=http://localhost:7000/api/webhooks/execution-service
EXECUTION_SERVICE_WEBHOOK_SECRET=
