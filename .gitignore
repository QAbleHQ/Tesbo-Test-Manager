# Kubernetes secrets (contain real credentials)
infra/kubernetes/**/secret.yaml
infra/kubernetes/base/registry-secret.yaml

# Root-level dependencies
/node_modules/
/Tesbo-Automation-Agents/node_modules/

# Backend build output
/Tesbo-Backend/target/
*.class

# Runtime logs and lock files
/Tesbo-Backend/logs/*.log
/Tesbo-Backend/logs/*.lck

# Local uploaded/generated artifacts
/Tesbo-Backend/uploads/tesbo-artifacts/
/Tesbo-Automation-Agents/artifacts/

# Local validation screenshots
/localhost-screenshot.png
/localhost-run-detail-screenshot.png
/localhost-test-detail-screenshot.png
/portal-tesbo-screenshot.png

# Stale/local-only directories
/automation-agent/
/backend/
/frontend/

# Tesbo-Execution (separate repository)
/Tesbo-Execution/

