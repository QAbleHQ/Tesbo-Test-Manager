PORT=7400
AUTOMATION_SERVICE_ROLE=all
PLAYWRIGHT_HEADLESS=true
SESSION_TTL_MS=900000
SESSION_CREATE_CONCURRENCY=2
START_URL_TIMEOUT_MS=60000
SCREENSHOT_DIR=./artifacts/screenshots
VIDEO_DIR=./artifacts/videos
TRACE_DIR=./artifacts/traces
# Use telemetry (step-by-step LLM mode) vs full autonomous agent mode.
USE_TELEMETRY=true
LANGCHAIN_MAX_STEPS=100
DOM_SNAPSHOT_MAX_ELEMENTS=120
RECORD_VIDEO=true
AGENT_SHARED_TOKEN=change-me
AUTOMATION_PROVIDER_LAMBDATEST_ENABLED=false
AUTOMATION_PROVIDER_BROWSERSTACK_ENABLED=false
