PORT=7000
# Use a PostgreSQL role that exists on your server (e.g. your OS username if using Homebrew Postgres)
DATABASE_URL=jdbc:postgresql://localhost:5432/bettercases
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=noreply@example.com
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
# Static OTP for testing when mail is not integrated (e.g. 123456). Leave empty when using Postmark.
STATIC_OTP=123456
SESSION_DAYS=30
# Jira OAuth 2.0 (3LO) — register an OAuth app at https://developer.atlassian.com/console/myapps/
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:3000/jira/callback
FRONTEND_URL=http://localhost:3000
