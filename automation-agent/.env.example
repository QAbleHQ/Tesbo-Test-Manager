PORT=7400
AUTOMATION_SERVICE_ROLE=all
PLAYWRIGHT_HEADLESS=true
SESSION_TTL_MS=900000
SESSION_CREATE_CONCURRENCY=2
START_URL_TIMEOUT_MS=60000
SCREENSHOT_DIR=./artifacts/screenshots
TRACE_DIR=./artifacts/traces
STAGEHAND_CACHE_DIR=./artifacts/stagehand-cache
# Use telemetry (observe→act per step) vs full agent mode. Default true = telemetry (produces Playwright scripts from successful acts).
# Set to false for agent mode (may perform more actions but scripts can be wait/scroll only).
USE_TELEMETRY=true
AGENT_SHARED_TOKEN=change-me
AUTOMATION_QUEUE_ENABLED=true
REDIS_URL=redis://localhost:6379
AUTOMATION_QUEUE_PREFIX=bull
AUTOMATION_QUEUE_NAME=automation-execution-jobs
AUTOMATION_QUEUE_MAX_RETRIES=2
AUTOMATION_QUEUE_CONCURRENCY=2
AUTOMATION_QUEUE_HEARTBEAT_MS=5000
AUTOMATION_PROVIDER_LAMBDATEST_ENABLED=false
AUTOMATION_PROVIDER_BROWSERSTACK_ENABLED=false
BACKEND_BASE_URL=http://localhost:7000
AUTOMATION_QUEUE_SHARED_TOKEN=change-me
