# Copy to .env to override the default one-command Docker deployment.

# Public ports on your machine.
FRONTEND_PORT=3000
BACKEND_PORT=7000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Database credentials used by the postgres and backend containers.
POSTGRES_DB=tesbo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Browser-facing URLs.
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:7000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JIRA_REDIRECT_URI=http://localhost:3000/jira/callback

# Optional integrations.
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=noreply@example.com
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Local artifact storage is used by default.
TESBO_ARTIFACT_STORAGE_PROVIDER=local

# Nest backend specific.
MAX_UPLOAD_SIZE=10485760
