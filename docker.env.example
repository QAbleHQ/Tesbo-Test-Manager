# Copy to .env to override the default one-command Docker deployment.

# Public ports on your machine (frontend + backend only).
FRONTEND_PORT=1010
BACKEND_PORT=1011

# Database credentials — use a long random password in production.
# Postgres is NOT published to the host; it is reachable only on the internal Docker network.
POSTGRES_DB=tesbo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# Redis is internal-only and password-protected. Backend does not use it today,
# but a password is required so Redis is never accidentally left open.
REDIS_PASSWORD=change-me-to-a-long-random-password

# Browser-facing URLs.
FRONTEND_URL=http://localhost:1010
NEXT_PUBLIC_API_URL=http://localhost:1011
CORS_ALLOWED_ORIGINS=http://localhost:1010,http://127.0.0.1:1010,http://localhost:3000,http://127.0.0.1:3000
JIRA_REDIRECT_URI=http://localhost:1010/jira/callback

# Optional integrations.
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=noreply@example.com
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Local artifact storage is used by default.
TESBO_ARTIFACT_STORAGE_PROVIDER=local

# Nest backend specific.
MAX_UPLOAD_SIZE=10485760
