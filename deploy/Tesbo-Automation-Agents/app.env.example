PORT=7400
AGENT_SHARED_TOKEN=your-shared-token-here
ENABLE_WEBSOCKET_LIVE_STREAM=true
SESSION_REPOSITORY_MODE=memory
ENABLE_REDIS_SESSION_REPOSITORY=false
REDIS_URL=redis://redis:6379
REDIS_PREFIX=tesbo:auto
REDIS_SESSION_TTL_SECONDS=1800
REDIS_LOCK_TTL_MS=15000
REDIS_HEARTBEAT_INTERVAL_MS=5000
WS_HEARTBEAT_MS=15000
WS_CLIENT_IDLE_TIMEOUT_MS=90000
