PORT=7000

# PostgreSQL
# Use JDBC URL format. Example:
# DATABASE_URL=jdbc:postgresql://db-host:5432/bettercases?sslmode=require
DATABASE_URL=jdbc:postgresql://your-postgres-host:5432/bettercases?sslmode=require
DATABASE_USER=postgres
DATABASE_PASSWORD=changeme

# CORS and app URLs
CORS_ALLOWED_ORIGINS=https://app.example.com
FRONTEND_URL=https://app.example.com

# Auth/session
SESSION_DAYS=30

# Email (OTP and alerts)
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=noreply@example.com

# Jira OAuth (optional)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=https://app.example.com/jira/callback

# Artifact storage
# local: saves under /app/uploads (mounted to ./uploads in compose)
# spaces: stores in DigitalOcean Spaces
TESBO_ARTIFACT_STORAGE_PROVIDER=local
TESBO_SPACES_ENDPOINT=
TESBO_SPACES_REGION=us-east-1
TESBO_SPACES_BUCKET=
TESBO_SPACES_ACCESS_KEY=
TESBO_SPACES_SECRET_KEY=
TESBO_SIGNED_URL_TTL_SECONDS=600
