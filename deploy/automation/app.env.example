PLAYWRIGHT_HEADLESS=true
SESSION_TTL_MS=900000
SESSION_CREATE_CONCURRENCY=2
START_URL_TIMEOUT_MS=60000
SCREENSHOT_DIR=/app/artifacts/screenshots
TRACE_DIR=/app/artifacts/traces
USE_TELEMETRY=true
LANGCHAIN_MAX_STEPS=30
DOM_SNAPSHOT_MAX_ELEMENTS=120

AUTOMATION_QUEUE_ENABLED=true
REDIS_URL=rediss://default:password@your-managed-redis-host:25061
AUTOMATION_QUEUE_PREFIX=bull
AUTOMATION_QUEUE_NAME=automation-execution-jobs
AUTOMATION_QUEUE_MAX_RETRIES=2
AUTOMATION_QUEUE_HEARTBEAT_MS=5000

# Backend service base URL reachable from automation droplet
BACKEND_BASE_URL=http://your-backend-ip:80

# Must match backend AUTOMATION_QUEUE_SHARED_TOKEN
AUTOMATION_QUEUE_SHARED_TOKEN=change-me

# Shared token for session/internal API auth
AGENT_SHARED_TOKEN=change-me
